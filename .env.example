# ============================================================
# LLM API
# ============================================================
GEMINI_API_KEY=                    # Google AI Studio API Key (필수)
OPENAI_API_KEY=                    # OpenAI API Key (임베딩 대안, 선택)

# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql+asyncpg://agent:agent_dev_password@localhost:5432/agentic_capital
DB_PASSWORD=agent_dev_password
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                    # Qdrant Cloud 사용 시

# ============================================================
# 거래소 API — 암호화폐
# ============================================================
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# ============================================================
# 거래소 API — 미국 주식
# ============================================================
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ============================================================
# 거래소 API — 국내 주식
# ============================================================
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=                    # 계좌번호 (예: 50012345-01)
KIS_IS_PAPER=true

# ============================================================
# 시뮬레이션 설정
# ============================================================
SIMULATION_SEED=42
INITIAL_CAPITAL=1000000
LOG_LEVEL=INFO

# ============================================================
# LangSmith (선택 — 트레이싱/디버깅)
# ============================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-capital
